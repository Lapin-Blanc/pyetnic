<xsd:schema xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:req="http://etnic.be/types/technical/requestId/v1" xmlns:status="http://etnic.be/types/technical/ResponseStatus/v3" xmlns:common="http://etnic.be/types/technical/common/v2" attributeFormDefault="unqualified" elementFormDefault="qualified" targetNamespace="http://etnic.be/types/technical/common/v2" version="2.0">
